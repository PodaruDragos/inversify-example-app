# Never Commit This File To Github
# This Is For The Sake Of The Example

# App
APP_ENV=development
APP_HOST=http://localhost:3000
APP_PORT=3000
APP_ROOT_PATH=/api/v1
APP_STATIC_PATH=/public

# Postgresql Configuration
POSTGRES_DB=test_db
POSTGRES_HOST=postgres
POSTGRES_PASSWORD=admin
POSTGRES_PORT=5432
POSTGRES_USER=postgres

# PGAdmin Configuration
PGADMIN_DEFAULT_EMAIL=username@user.com
PGADMIN_DEFAULT_PASSWORD=pgadmin

# MikroORM Configuration
MIKRO_ORM_DB_NAME=test_db
MIKRO_ORM_HOST=localhost
MIKRO_ORM_ENTITIES=bin/entities/*.js
MIKRO_ORM_ENTITIES_TS=src/entities/*.ts
MIKRO_ORM_MIGRATIONS_PATH=src/migrations
MIKRO_ORM_MIGRATIONS_PATTERN = ^[\w-]+\d+\.ts$
MIKRO_ORM_PASSWORD=admin
MIKRO_ORM_PORT=5432
MIKRO_ORM_TYPE=postgresql
MIKRO_ORM_USER=postgres
